# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Authentication
JWT_SECRET=your-random-64-char-secret-here
SESSION_SECRET=your-random-64-char-session-secret

# Nova AI Connection
NOVA_API_URL=https://nova-api.railway.app
NOVA_API_KEY=sk-nova-your-api-key
NOVA_TENANT_ID=your-tenant-id

# Environment
NODE_ENV=development
PORT=5000
